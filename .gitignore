# Local editor/IDE
.idea/
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS
.DS_Store
Thumbs.db

# Secrets (never commit)
*.env
*.key
*.pem
.env.*

# Local Claude Code state — ignore everything under .claude/ EXCEPT
# project-level config (settings.json) and shared hooks scripts
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/hooks/*
!.claude/hooks/*.sh

# Install manifest (written by install-skills.sh)
.install_manifest
